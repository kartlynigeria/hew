// Test: Verify self-transitions preserve payload fields
// Exercises: wildcard self-transitions, explicit self-transitions, field preservation
machine Keeper {
    state Holding { value: Int; }
    state Empty;

    event Poke;
    event Drop;

    on Poke: Holding -> Holding { state }
    on Poke: Empty -> Empty { state }
    on Drop: Holding -> Empty { Empty }
    on Drop: Empty -> Empty { state }
}

fn main() -> Int {
    var k = Keeper::Holding { value: 42 };
    k.step(KeeperEvent::Poke);
    k.step(KeeperEvent::Poke);

    match k {
        Holding { value } => {
            println(f"value = {value}");
            if value == 42 { println("PASS"); 0 } else { println("FAIL: wrong value"); 1 }
        },
        _ => { println("FAIL: wrong state"); 1 },
    }
}
