// Test: Machine with state payload fields and transition body execution
// Exercises: state fields, variant construction in bodies, state.field access
machine Counter {
    state Zero;
    state Count { n: Int; }

    event Inc;
    event Reset;

    on Inc: Zero -> Count { Count { n: 1 } }
    on Inc: Count -> Count { Count { n: state.n + 1 } }
    on Reset: Zero -> Zero { Zero }
    on Reset: Count -> Zero { Zero }
}

fn main() -> Int {
    var c = Counter::Zero;
    c.step(CounterEvent::Inc);
    c.step(CounterEvent::Inc);
    c.step(CounterEvent::Inc);

    match c {
        Count { n } => {
            println(f"count = {n}");
            if n == 3 { println("PASS"); 0 } else { println("FAIL"); 1 }
        },
        _ => { println("FAIL: wrong state"); 1 },
    }
}
