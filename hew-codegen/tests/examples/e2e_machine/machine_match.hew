// Test: Machine with pattern matching and wildcard self-transitions
// Exercises: match on machine states, wildcard _ -> _ transitions, describe function
machine Door {
    state Locked;
    state Unlocked;
    state Open;

    event Lock;
    event Unlock;
    event Push;
    event Pull;

    on Unlock: Locked -> Unlocked;
    on Lock: Unlocked -> Locked;
    on Push: Unlocked -> Open;
    on Pull: Open -> Unlocked;

    // Wildcard self-transitions for invalid actions
    on Lock: _ -> _ { state }
    on Unlock: _ -> _ { state }
    on Push: _ -> _ { state }
    on Pull: _ -> _ { state }
}

fn describe(d: Door) -> String {
    match d {
        Locked => "The door is locked",
        Unlocked => "The door is unlocked",
        Open => "The door is open",
    }
}

fn main() -> int {
    var door = Door::Locked;
    println(describe(door));

    // Unlock
    door.step(Unlock);
    println(describe(door));

    // Push open
    door.step(Push);
    println(describe(door));

    // Pull closed
    door.step(Pull);
    println(describe(door));

    // Lock
    door.step(Lock);
    println(describe(door));

    // Invalid: push a locked door (stays locked)
    door.step(Push);
    println(describe(door));

    0
}
