// Test: Basic Machine — toggle light switch
// Exercises: machine declaration, state/event, step(), state_name(), qualified constructors
machine Light {
    state Off;
    state On;
    event Toggle;
    on Toggle: Off -> On;
    on Toggle: On -> Off;
}

fn main() -> int {
    var light = Light::Off;
    println(light.state_name());
    light = light.step(Toggle);
    println(light.state_name());
    light = light.step(Toggle);
    println(light.state_name());
    0
}
