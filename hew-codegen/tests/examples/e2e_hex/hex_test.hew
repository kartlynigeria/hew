import std::encoding::hex;

fn main() {
    // Encode known bytes
    let data = bytes [0xDE, 0xAD, 0xBE, 0xEF];
    let s = hex.encode(data);
    println(s);

    // Uppercase
    let u = hex.encode_upper(data);
    println(u);

    // Round-trip decode
    let back = hex.decode(s);
    println(back.len());
    println(back.get(0));
    println(back.get(3));

    // Empty encode
    let empty = b"";
    let es = hex.encode(empty);
    println(es);

    // Single byte
    let one = bytes [0x0F];
    println(hex.encode(one));
}
