// Test: Fan-Out Fan-In (MapReduce pattern)
// Exercises: Multiple worker actors processing in parallel
actor Worker {
    let id: int;
    receive fn compute(n: int) -> int {
        let result = n * n;
        print("Worker ");
        print(self.id);
        print(": ");
        print(n);
        println(f"^2 = {result}");
        result
    }
}

fn main() {
    println("=== Fan Out Fan In ===");
    let w1 = spawn Worker(id: 1);
    let w2 = spawn Worker(id: 2);
    let w3 = spawn Worker(id: 3);
    // Use await for deterministic ordering (no sleeps needed)
    await w1.compute(2);
    await w2.compute(3);
    await w3.compute(4);
    await w1.compute(5);
    await w2.compute(6);
    await w3.compute(7);
    println("Done");
}
