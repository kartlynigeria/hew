fn main() {
    let m: HashMap<String, int> = HashMap::new();
    m.insert("x", 10);
    m.insert("y", 20);
    m.insert("z", 30);

    let keys = m.keys();
    println(keys.len());

    // Sum values via key lookup (order-independent)
    var sum = 0;
    for i in 0..keys.len() {
        let k = keys[i];
        match m.get(k) {
            Some(v) => { sum = sum + v; },
            None => {},
        }
    }
    println(sum);
}
