fn main() {
    var words: Vec<String> = Vec::new();
    words.push("hello");
    words.push("world");
    words.push("foo");
    println(words.join(", "));
    println(words.join("-"));
    println(words.join(""));

    var empty: Vec<String> = Vec::new();
    println(empty.join(","));

    var single: Vec<String> = Vec::new();
    single.push("only");
    println(single.join(","));
}
