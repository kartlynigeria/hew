fn main() {
    let text = "hello\nworld\nfoo";
    let parts = text.lines();
    println(parts.len());
    for i in 0..parts.len() {
        println(parts[i]);
    }

    // Test with trailing newline
    let text2 = "a\nb\n";
    let parts2 = text2.lines();
    println(parts2.len());
    for i in 0..parts2.len() {
        println(parts2[i]);
    }
}
