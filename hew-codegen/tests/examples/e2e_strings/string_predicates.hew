fn main() {
    println("123".is_digit());
    println("abc".is_digit());
    println("12a".is_digit());
    println("".is_digit());

    println("hello".is_alpha());
    println("hello1".is_alpha());
    println("123".is_alpha());
    println("".is_alpha());

    println("abc123".is_alphanumeric());
    println("abc 123".is_alphanumeric());
    println("".is_alphanumeric());

    println("".is_empty());
    println("hi".is_empty());
}
